# Socket Mode app-level token (starts with xapp-)
# Generate at: Slack App → Basic Information → App-Level Tokens → add "connections:write" scope
SLACK_APP_TOKEN=

# Bot user OAuth token (starts with xoxb-)
# Found at: Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=

# Optional: control log verbosity (default: info)
# RUST_LOG=hermes=debug
